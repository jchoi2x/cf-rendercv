{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2021",
    "lib": ["ES2021"],
    
    /* Modules */
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    
    /* Emit */
    "noEmit": true,
    
    /* Interop Constraints */
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Type Checking */
    "strict": true,
    "skipLibCheck": true
  }
}
