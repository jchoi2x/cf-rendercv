{
  "name": "cf-rendercv",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:http": "cd apps/http && bun run dev",
    "dev:api": "cd apps/rendercv-app && bun run dev",
    "build:http": "cd apps/http && bun run build",
    "build:api": "cd apps/rendercv-app && bun run build",
    "build": "bun run build:http && bun run build:api",
    "deploy:http": "cd apps/http && bun run deploy",
    "deploy": "bun run build:api && bun run deploy:http",
    "format": "biome format --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:http": "eslint apps/http",
    "lint:api": "eslint apps/rendercv-app",
    "lint:biome": "biome lint --fix",
    "start": "cd apps/http && bun run start",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:unit:coverage": "cd apps/http && bun run test:coverage && cd ../rendercv-app && bun run test:coverage",
    "test:http": "cd apps/http && bun run test",
    "test:api": "cd apps/rendercv-app && bun run test",
    "test:e2e:api": "cd apps/rendercv-app && bun run test:e2e",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test": "bun run test:http && bun run test:api"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.2",
    "@types/node": "^25.0.3",
    "@biomejs/biome": "^2.3.10",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-newlines": "^1.4.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.1.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.1.0"
}
