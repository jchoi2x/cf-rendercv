{
  "name": "cf-rendercv",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:http": "pnpm --filter @cf-rendercv/http dev",
    "dev:api": "pnpm --filter @cf-rendercv/rendercv-app dev",
    "build:http": "pnpm --filter @cf-rendercv/http build",
    "build:api": "pnpm --filter @cf-rendercv/rendercv-app build",
    "build": "pnpm -r build",
    "deploy:http": "pnpm run --filter @cf-rendercv/http deploy",
    "deploy": "pnpm run build:api && pnpm run deploy:http",
    "format": "biome format --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:http": "eslint apps/http",
    "lint:api": "eslint apps/rendercv-app",
    "lint:biome": "biome lint --fix",
    "start": "pnpm --filter @cf-rendercv/http start",
    "test:http": "pnpm --filter @cf-rendercv/http test",
    "test:api": "pnpm --filter @cf-rendercv/rendercv-app test",
    "test:e2e:api": "pnpm --filter @cf-rendercv/rendercv-app test:e2e",
    "test": "pnpm --filter @cf-rendercv/http test && pnpm --filter @cf-rendercv/rendercv-app test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-newlines": "^1.4.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.16"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2"
}
