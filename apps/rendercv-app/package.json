{
  "name": "@cf-rendercv/rendercv-app",
  "description": "Cloudflare container for rendercv in node",
  "author": {
    "name": "James Choi",
    "url": "https://github.com/jchoi2x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jchoi2x/cf-rendercv.git"
  },
  "license": "LGPL-3.0-or-later",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "pnpm typecheck && node build.js",
    "deploy": "echo noop",
    "typecheck": "tsc --noEmit --project tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@cf-rendercv/contracts": "workspace:*",
    "@hono/node-server": "^1.12.0",
    "@hono/swagger-ui": "^0.3.0",
    "@hono/zod-openapi": "^1.2.2",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.6.0",
    "js-yaml": "^4.1.1",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "rimraf": "^6.1.3",
    "tough-cookie": "^4.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cookie": "^0.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.27",
    "@types/rimraf": "^4.0.5",
    "@types/tough-cookie": "^4.0.5",
    "@types/user-agents": "^1.0.4",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.50.1"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
