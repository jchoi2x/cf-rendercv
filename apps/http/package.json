{
  "name": "@cf-rendercv/http",
  "version": "1.0.0",
  "description": "MCP Server on Cloudflare Worker for Suno AI",
  "main": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "format": "biome format --write",
    "lint": "NODE_OPTIONS='--no-warnings' eslint .",
    "lint:fix": "NODE_OPTIONS='--no-warnings' eslint . --fix",
    "lint:biome": "biome lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@cf-rendercv/contracts": "workspace:*",
    "@cloudflare/containers": "^0.0.30",
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@jchoi2x/typst-ts-web-compiler": "0.7.4",
    "@jchoi2x/typst.ts": "0.7.4",
    "@jchoi2x/typst-ts-renderer": "0.7.5",
    "@mcp-ui/server": "^6.1.0",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@openrouter/minijinja": "^0.1.1",
    "agents": "^0.3.3",
    "hono": "^4.11.3",
    "jose": "^6.2.2",
    "@jchoi2x/minijinja": "0.0.8",
    "mustache": "^4.2.0",
    "nunjucks": "^3.2.4",
    "oauth4webapi": "^3.8.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@cloudflare/vitest-pool-workers": "^0.13.2",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.0.3",
    "@types/nunjucks": "^3.2.6",
    "typescript": "^5.3.3",
    "wrangler": "^4.73.0"
  }
}
