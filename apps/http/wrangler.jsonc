{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rendercv-http",
  "main": "src/index.ts",
  "dev": {
    "port": 8787
  },
  "compatibility_date": "2025-11-17",
  "vars": {
    "TYPST_COMPILER_WASM_URL": "https://github.com/jchoi2x/typst.ts/raw/refs/heads/main-bun/packages/compiler/pkg/typst_ts_web_compiler_bg.wasm"
  },
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "rules": [
    {
      "type": "Text",
      "globs": [
        "**/*.html"
      ],
      "fallthrough": true,
    },
    {
      "type": "Text",
      "globs": [
        "**/*.j2.typ"
      ],
      "fallthrough": true,
    },
    {
      "type": "Text",
      "globs": [
        "**/*.typ",
        "**/*.yaml",
        "**/*.yml",
      ]
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": false,
      "destinations": [
        "datadog-otel-logs"
      ],
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "destinations": [
        "datadog-otel-traces"
      ],
      "head_sampling_rate": 1,
      "persist": false
    }
  },
  "containers": [
    {
      "class_name": "DockerRendercvApp",
      "image": "../rendercv-app/Dockerfile",
      "name": "rendercv-app",
      "image_build_context": "../..",
      "max_instances": 10
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "DockerRendercvApp",
        "name": "DOCKER_RENDERCV_APP"
      },
      {
        "class_name": "TypstCompilerDo",
        "name": "TYPST_COMPILER"
      },
      {
        "class_name": "RendercvDo",
        "name": "MCP_OBJECT"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": [
        "DockerRendercvApp"
      ],
      "tag": "v1"
    },
    {
      "new_sqlite_classes": [
        "RendercvDo"
      ],
      "tag": "v2"
    },
    {
      "new_sqlite_classes": [
        "TypstCompilerDo"
      ],
      "tag": "v3"
    }
  ],
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      // Replace with your Cloudflare Rate Limit namespace UUID.
      // This must be a UUID (Wrangler validates the format).
      "namespace_id": "10110101010111",
      "simple": {
        "limit": 100,
        "period": 60
      }
    }
  ],
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "686aae8546fd42e088c9cf6df5cfb2a9",
      "preview_id": "bf19dba2e28e4451a86f00b588a4295e"
    }
  ]
}